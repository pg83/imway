#cloud-config
hostname: imway-dev

users:
  - name: dev
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: true
    groups: [video, render, input]
    ssh_authorized_keys:
      - @SSH_PUBKEY@

package_update: true
package_upgrade: false

packages:
  # the cloud kernel lacks virtio_gpu — install the full one (provides /dev/dri)
  - linux-image-arm64
  # toolchain
  - build-essential
  - cmake
  - ninja-build
  - pkg-config
  - git
  - rsync
  - gdb
  - ccache
  # imway dependencies
  - libwayland-dev
  - wayland-protocols
  - libdrm-dev
  - libinput-dev
  - libudev-dev
  - libev-dev
  - libxkbcommon-dev
  - libseat-dev
  - seatd
  - wl-clipboard
  - fonts-dejavu-core
  - libseat-dev
  - libvulkan-dev
  # vulkan runtime (lavapipe in mesa-vulkan-drivers) and tools
  - mesa-vulkan-drivers
  - vulkan-tools
  - vulkan-validationlayers
  - glslang-tools
  - spirv-tools
  # tooling for manual testing
  - seatd
  - wl-clipboard
  - fonts-dejavu-core
  - sway
  - foot
  - wayland-utils
  - wl-clipboard
  - fonts-dejavu-core
  - libinput-tools
  - drm-info

write_files:
  # udmabuf — dmabuf export for lavapipe; uinput — input injection in tests
  - path: /etc/modules-load.d/imway.conf
    content: |
      udmabuf
      uinput
  - path: /etc/udev/rules.d/99-imway.rules
    content: |
      KERNEL=="udmabuf", GROUP="render", MODE="0660"
      KERNEL=="uinput", GROUP="input", MODE="0660"

runcmd:
  - modprobe udmabuf || true
  - modprobe uinput || true
  - udevadm control --reload && udevadm trigger || true
